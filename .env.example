# Public site URL (canonical links, Open Graph, and `npm run build` sitemap URLs).
# `prebuild` runs `scripts/generate-sitemap.mjs`, which reads this from `.env` when present.
VITE_SITE_URL=https://venilabs.viilasa.com

# Optional: custom form backend (JSON POST, Formspree-style). If unset, submissions go through FormSubmit → inbox in `src/lib/siteLinks.js`.
# VITE_CONTACT_FORM_ENDPOINT=
